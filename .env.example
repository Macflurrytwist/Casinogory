# Discord Developer Portal → your application
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: set for instant command updates in one server while testing.
# Leave blank to register commands globally (takes up to ~1hr to propagate).
DISCORD_GUILD_ID=

# Your live CASINOGORY backend, e.g. https://casinogory.onrender.com/api
GAME_API_BASE=https://casinogory.onrender.com/api

# Must match DISCORD_BOT_SHARED_SECRET set on the backend — this is how
# the backend trusts that /api/auth/discord requests really came from
# this bot and not from anyone who can guess a Discord ID.
DISCORD_BOT_SHARED_SECRET=
